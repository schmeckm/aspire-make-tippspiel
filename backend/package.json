{
  "name": "wm2026-tippspiel-backend",
  "version": "1.0.5",
  "description": "Backend für WM 2026 Tippspiel v1.0.1",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node database/seed.js",
    "db:migrate": "node database/migrate-cli.js",
    "db:backup-pg": "node database/postgres-backup-cli.js",
    "backup:player-data": "node database/player-data-backup-cli.js",
    "db:reset": "node database/reset.js",
    "db:create-admin": "node database/create-admin.js",
    "db:seed-teams": "node database/seed-teams.js",
    "test": "node tests/run-all.js",
    "test:unit": "node tests/run-all.js unit",
    "test:integration": "node tests/run-all.js integration",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm test"
