    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "openai": "^4.85.4",
    "openid-client": "^5.7.1",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
