{
  "name": "wm2026-tippspiel-backend",
  "version": "2.5.0",
  "description": "Backend für WM 2026 Tippspiel MVP 2.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node database/seed.js",
    "db:migrate": "node database/migrate-cli.js",
    "db:backup-pg": "node database/postgres-backup-cli.js",
    "db:reset": "node database/reset.js",
    "db:seed-teams": "node database/seed-teams.js",
    "test": "node --require ./tests/helpers/testEnv.js --test tests/**/*.test.js tests/unit/**/*.test.js tests/integration/**/*.test.js",
    "test:unit": "node --require ./tests/helpers/testEnv.js --test tests/unit/**/*.test.js",
    "test:integration": "node --require ./tests/helpers/testEnv.js --test tests/integration/**/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "openai": "^4.85.4",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "supertest": "^7.2.2"
  }
}
