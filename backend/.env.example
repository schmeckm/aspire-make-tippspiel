PORT=3000
# Optional: override package.json version (set automatically in Docker from GitHub release tag)
# APP_VERSION=1.0.1
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_TTL_MS=2592000000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Optional: shared state for rate limits, OAuth, JWT blacklist (multi-instance production)
# REDIS_URL=redis://localhost:6379

# Optional: restrict TV display mode to specific IPs (comma-separated)
# DISPLAY_ALLOWED_IPS=192.168.1.100,10.0.0.5

# Database (sqlite or postgres)
DB_DIALECT=sqlite
DB_PATH=./database/wm2026.sqlite
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=wm2026
# DB_USER=postgres
# DB_PASSWORD=postgres

# Registration
OPEN_REGISTRATION=true
# Schema-Änderungen: npm run db:migrate (fügt Spalten hinzu, löscht keine Daten)
# Vollständiger Reset:  npm run db:reset -- --confirm (erstellt vorher Backup)
# Tipps schützen (Standard): Spiele mit Tipps werden nicht gelöscht; Backup überschreibt keine Tipps
# PREDICTION_PROTECT_STRICT=false  # nur für bewusstes Admin-Override – sonst nie setzen
# Football API – football-data.org v4 (primärer Provider)
FOOTBALL_API_PROVIDER=football-data
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=
FOOTBALL_API_COMPETITION_CODE=WC
FOOTBALL_API_COMPETITION_NUMERIC_ID=2000
FOOTBALL_API_COMPETITION_ID=WC
FOOTBALL_API_SEASON=2026
FOOTBALL_API_TIMEZONE=Europe/Zurich
FOOTBALL_API_SYNC_ENABLED=false
FOOTBALL_API_RESULT_SYNC_ENABLED=false

# Tournament dates (for cron scheduling)
TOURNAMENT_START=2026-06-11
TOURNAMENT_END=2026-07-20

# Sentry (optional – error monitoring + cron check-ins during live matches)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=wm2026-backend@1.0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_CRON_TIMEZONE=Europe/Zurich

# Backups (automated via scheduler – daily 03:00 DB, 03:30 uploads, hourly player data)
# BACKUP_OFFSITE_DIR=/path/to/offsite/backups
# BACKUP_PG_RETENTION=14
# BACKUP_SQLITE_RETENTION=7
# BACKUP_UPLOADS_RETENTION=7
# PLAYER_DATA_BACKUP_ENABLED=true
# PLAYER_DATA_BACKUP_CRON=0 * * * *
# PLAYER_DATA_BACKUP_RETENTION=168
# LEADERBOARD_CACHE_TTL_MS=45000
# SQLITE_BUSY_TIMEOUT=5000
# PASSWORD_MIN_LENGTH=10
# EMAIL_QUEUE_CONCURRENCY=5
# REDIS_URL=redis://localhost:6379

# Email (SMTP) – required for verification, password reset & reminders
# Without SMTP, links are logged to the backend console as [Email mock]
# EMAIL_REMINDERS_ENABLED=true   # default: auto-on in production when SMTP is configured
# MORNING_DIGEST_ENABLED=true    # daily morning newsletter (independent from tip reminders)
# EMAIL_REMINDERS_AUTO_ENABLE=true
# REMINDER_TIMEZONE=Europe/Zurich
# REMINDER_MATCH_WINDOW_HOURS=48
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tippspiel.local
SMTP_SECURE=false

# App URL (for email links: verify-email, reset-password, reminders)
APP_URL=http://localhost:5173

# Google SSO (optional – leave empty to disable; classic email/password login always remains available)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev (Windows+WSL): use Vite proxy — localhost:3000 may hit WSL instead of Node
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
# Optional: restrict SSO to company email domains (comma-separated, e.g. aspiremake.com,aspiremake.ch)
SSO_ALLOWED_EMAIL_DOMAINS=

# AI / OpenAI (optional)
# Set to false to skip auto-import of the official WM 2026 schedule when the DB has few matches
WM2026_AUTO_SEED_SCHEDULE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_FEATURES_ENABLED=true
AI_CACHE_ENABLED=true
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.4
AI_ADMIN_FEATURES_ENABLED=true
AI_USER_COACH_ENABLED=true
AI_MATCH_PREVIEW_ENABLED=true
AI_LEADERBOARD_COMMENTARY_ENABLED=true

# Player images + venue enrichment (TheSportsDB – free public key: 123)
PLAYER_IMAGE_ENABLED=true
PLAYER_IMAGE_THESPORTSDB_API_KEY=123
PLAYER_IMAGE_THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
THESPORTSDB_VENUE_ENRICHMENT_ENABLED=true
THESPORTSDB_LEAGUE_ID=4429
THESPORTSDB_SEASON=2026
PLAYER_IMAGE_CACHE_TTL_DAYS=30
PLAYER_IMAGE_RATE_LIMIT_MS=3000
PLAYER_IMAGE_RATE_LIMIT_COOLDOWN_MS=900000
# Wikimedia APIs (2026 rate limits): set a real contact email + APP_URL for User-Agent policy
PLAYER_IMAGE_WIKIMEDIA_ENABLED=true
WIKIMEDIA_CONTACT_EMAIL=
WIKIMEDIA_API_MIN_INTERVAL_MS=6000
WIKIMEDIA_API_MAX_CONCURRENT=2

# Player images: wave sync (small batches to avoid load)
# Default: enabled (set to false to disable)
PLAYER_IMAGE_WAVE_ENABLED=true
# Run at minute 15 every hour
PLAYER_IMAGE_WAVE_CRON=15 * * * *
# How many players per run (kept small)
PLAYER_IMAGE_WAVE_BATCH_SIZE=30
# Max runtime per wave run (ms)
PLAYER_IMAGE_WAVE_TIME_BUDGET_MS=60000
