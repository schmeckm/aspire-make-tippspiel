## Frontend env (Vite)
#
# NOTE: Vite only exposes variables prefixed with VITE_.
# These values are used for date/time formatting (not only cron scheduling).
#
# Example:
# VITE_DEFAULT_TIMEZONE=Europe/Zurich

VITE_DEFAULT_TIMEZONE=Europe/Zurich

VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_AI_FEATURES_ENABLED=true
VITE_APP_URL=
VITE_APP_VERSION=
VITE_APP_COMMIT_SHA=
