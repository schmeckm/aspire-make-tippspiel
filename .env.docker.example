# Kopie als .env im Projektroot für docker compose (optional).
# Für Portainer: Variablen im Stack-Editor eintragen oder .env auf dem Server nutzen.
# Produktion: docker-compose.prod.yml (PostgreSQL)

PORT=3000
NODE_ENV=production
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080

# PostgreSQL (Produktion / docker-compose.prod.yml)
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=wm2026
DB_USER=wm2026
DB_PASSWORD=change-me-db-password

# SQLite (nur docker-compose.yml ohne postgres-Profil)
# DB_DIALECT=sqlite
# DB_PATH=./database/wm2026.sqlite

OPEN_REGISTRATION=true
FRONTEND_PORT=8080

FOOTBALL_API_PROVIDER=football-data
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
FOOTBALL_API_KEY=
FOOTBALL_API_COMPETITION_ID=WC
FOOTBALL_API_COMPETITION_NUMERIC_ID=2000
FOOTBALL_API_SEASON=2026
FOOTBALL_API_TIMEZONE=Europe/Zurich
FOOTBALL_API_SYNC_ENABLED=true
FOOTBALL_API_RESULT_SYNC_ENABLED=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_FEATURES_ENABLED=true
AI_CACHE_ENABLED=true
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.4
AI_ADMIN_FEATURES_ENABLED=true
AI_USER_COACH_ENABLED=true
AI_MATCH_PREVIEW_ENABLED=true
AI_LEADERBOARD_COMMENTARY_ENABLED=true

APP_URL=http://localhost:8080
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
